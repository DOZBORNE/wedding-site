# Supabase — same project as engagement-invite (Settings → API)
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Resend (resend.com) — verify your domain, then use e.g. rsvp@yourdomain.com
RESEND_API_KEY=re_...
RESEND_FROM="Devin & Jessica <rsvp@yourdomain.com>"
# Optional: where guest replies go. Any inbox — need not be on the verified domain.
RESEND_REPLY_TO=devin@osbornex.com

# Absolute URL of the deployed site (used in reminder links)
PUBLIC_SITE_URL=https://yourdomain.com

# Password for /admin
ADMIN_PASSWORD=pick-something-long

# Optional: secret for signing guest RSVP sessions (the code-scoped cookie).
# Leave blank and it derives from the service-role key — fine for one deployment.
RSVP_SESSION_SECRET=

# Optional: token that authorizes POST /api/reminders (for a cron job)
CRON_SECRET=

# Optional: Twilio for SMS reminders (leave blank to disable SMS)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
